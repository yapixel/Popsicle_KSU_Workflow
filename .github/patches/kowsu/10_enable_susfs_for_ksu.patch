index 40181a5b..3988bdcc 100644
--- a/kernel/feature/sucompat.c
+++ b/kernel/feature/sucompat.c
@@ -94,6 +94,7 @@ int ksu_handle_faccessat(int *dfd, const char __user **filename_user, int *mode,
     return 0;
 }
 
+#ifndef CONFIG_KSU_SUSFS
 int ksu_handle_stat(int *dfd, const char __user **filename_user, int *flags)
 {
     // const char sh[] = SH_PATH;
@@ -119,6 +120,8 @@ int ksu_handle_stat(int *dfd, const char __user **filename_user, int *flags)
 
     return 0;
 }
+#endif
+
 
 long ksu_handle_execve_sucompat(const char __user **filename_user, int orig_nr, const struct pt_regs *regs)
 {
diff --git a/kernel/feature/sucompat.h b/kernel/feature/sucompat.h
index 1afba60f..426efc8e 100644
--- a/kernel/feature/sucompat.h
+++ b/kernel/feature/sucompat.h
@@ -10,7 +10,10 @@ void ksu_sucompat_exit(void);
 
 // Handler functions exported for hook_manager
 int ksu_handle_faccessat(int *dfd, const char __user **filename_user, int *mode, int *__unused_flags);
+#ifndef CONFIG_KSU_SUSFS
 int ksu_handle_stat(int *dfd, const char __user **filename_user, int *flags);
+#endif
+
 long ksu_handle_execve_sucompat(const char __user **filename_user, int orig_nr, const struct pt_regs *regs);
 
 #endif
\ No newline at end of file
diff --git a/kernel/hook/syscall_event_bridge.c b/kernel/hook/syscall_event_bridge.c
index eb7ea937..266cf55e 100644
--- a/kernel/hook/syscall_event_bridge.c
+++ b/kernel/hook/syscall_event_bridge.c
@@ -130,3 +130,41 @@ long __nocfi ksu_hook_setresuid(int orig_nr, const struct pt_regs *regs)
     ksu_handle_setresuid(old_uid, current_uid().val);
     return ret;
 }
+
+#ifdef CONFIG_KSU_SUSFS
+#include <linux/susfs_def.h>
+int ksu_handle_execveat_sucompat(int *fd, struct filename **filename_ptr,
+                                 void *__never_use_argv, void *__never_use_envp,
+                                 int *__never_use_flags)
+{
+    struct filename *filename;
+    if (unlikely(!filename_ptr)) return 0;
+    filename = *filename_ptr;
+    if (IS_ERR(filename)) return 0;
+    if (likely(memcmp(filename->name, "/system/bin/su", 15))) return 0;
+    memcpy((void *)filename->name, "/data/adb/ksud", 15);
+    escape_with_root_profile();
+    return 0;
+}
+
+int ksu_handle_execveat(int *fd, struct filename **filename_ptr, void *argv,
+                        void *envp, int *flags)
+{
+    return ksu_handle_execveat_sucompat(fd, filename_ptr, argv, envp, flags);
+}
+
+int ksu_handle_devpts(struct inode *inode)
+{
+    uid_t uid;
+    if (!current->mm) return 0;
+    uid = current_uid().val;
+    if (uid % 100000 < 10000) return 0;
+    if (!__ksu_is_allow_uid_for_current(uid)) return 0;
+    if (ksu_file_sid) {
+        void *sec = selinux_inode(inode);
+        if (sec) ((struct { u32 magic; u32 sid; } *)sec)->sid = ksu_file_sid;
+    }
+    return 0;
+}
+#endif // CONFIG_KSU_SUSFS
+
diff --git a/kernel/kernel b/kernel/kernel
new file mode 120000
index 00000000..9e51d0d6
--- /dev/null
+++ b/kernel/kernel
@@ -0,0 +1 @@
+../KernelSU/kernel
\ No newline at end of file
diff --git a/kernel/runtime/ksud.h b/kernel/runtime/ksud.h
index 62cfaabf..859f647c 100644
--- a/kernel/runtime/ksud.h
+++ b/kernel/runtime/ksud.h
@@ -11,4 +11,22 @@ void ksu_ksud_exit();
 void ksu_execve_hook_ksud(const struct pt_regs *regs);
 void ksu_stop_input_hook_runtime(void);
 
+
+#ifdef CONFIG_KSU_SUSFS
+#ifndef MAX_ARG_STRINGS
+#define MAX_ARG_STRINGS 0x7FFFFFFF
+struct user_arg_ptr {
+#ifdef CONFIG_COMPAT
+    bool is_compat;
+#endif
+    union {
+        const char __user *const __user *native;
+#ifdef CONFIG_COMPAT
+        const compat_uptr_t __user *compat;
+#endif
+    } ptr;
+};
+#endif
+#endif // CONFIG_KSU_SUSFS
+
 #endif
diff --git a/kernel/runtime/ksud_integration.c b/kernel/runtime/ksud_integration.c
index 25933bb6..1782b3f1 100644
--- a/kernel/runtime/ksud_integration.c
+++ b/kernel/runtime/ksud_integration.c
@@ -46,11 +46,28 @@ static const char KERNEL_SU_RC[] =
     "\n";
 // clang-format on
 
+
+#ifdef CONFIG_KSU_SUSFS
+extern const size_t ksu_rc_len;
+void ksu_handle_vfs_fstat(int fd, loff_t *kstat_size_ptr) {
+    loff_t new_size = *kstat_size_ptr + ksu_rc_len;
+    struct file *file = fget(fd);
+    if (!file) return;
+    if (strcmp(current->comm, "init") == 0 && d_is_reg(file->f_path.dentry)) {
+        if (strcmp(file->f_path.dentry->d_name.name, "init.rc") == 0) {
+            *kstat_size_ptr = new_size;
+        }
+    }
+    fput(file);
+}
+#endif
+
 static void stop_init_rc_hook();
 static void stop_execve_hook();
 
 static struct work_struct stop_input_hook_work;
 
+#ifndef CONFIG_KSU_SUSFS
 #define MAX_ARG_STRINGS 0x7FFFFFFF
 struct user_arg_ptr {
 #ifdef CONFIG_COMPAT
@@ -63,6 +80,8 @@ struct user_arg_ptr {
 #endif
     } ptr;
 };
+#endif
+
 
 static const char __user *get_user_arg_ptr(struct user_arg_ptr argv, int nr)
 {
@@ -400,6 +419,10 @@ void ksu_execve_hook_ksud(const struct pt_regs *regs)
     }
 
     ksu_handle_execveat_ksud(path, &argv);
+#ifdef CONFIG_KSU_SUSFS
+    extern int ksu_handle_execveat_init(struct filename *filename);
+    (void)ksu_handle_execveat_init((struct filename *)path);
+#endif
 }
 
 static long (*orig_sys_read)(const struct pt_regs *regs);
@@ -471,9 +494,13 @@ static void do_stop_input_hook(struct work_struct *work)
 
 static void stop_init_rc_hook()
 {
+#ifndef CONFIG_KSU_SUSFS
     ksu_syscall_table_unhook(__NR_read);
     ksu_syscall_table_unhook(__NR_fstat);
     pr_info("unregister init_rc syscall hook\n");
+#else
+    ksu_init_rc_hook = false;
+#endif
 }
 
 void ksu_stop_input_hook_runtime(void)
diff --git a/kernel/supercall/supercall.c b/kernel/supercall/supercall.c
index cf03ce82..0956b6ee 100644
--- a/kernel/supercall/supercall.c
+++ b/kernel/supercall/supercall.c
@@ -13,6 +13,11 @@
 
 #include <linux/utsname.h> // utsname() and uts_sem
 
+#ifdef CONFIG_KSU_SUSFS
+#include <linux/namei.h>
+#include <linux/susfs.h>
+#endif
+
 #include "uapi/supercall.h"
 #include "supercall/internal.h"
 #include "arch.h"
@@ -93,6 +98,44 @@ extern uint32_t ksuflags_override;
 static int ksu_handle_sys_reboot(int magic1, int magic2, unsigned int cmd, void __user **arg)
 {
 
+#ifdef CONFIG_KSU_SUSFS
+    if (magic2 == SUSFS_MAGIC && current_uid().val == 0) {
+#ifdef CONFIG_KSU_SUSFS_SUS_PATH
+        if (cmd == CMD_SUSFS_ADD_SUS_PATH)            { susfs_add_sus_path(arg); return 0; }
+        if (cmd == CMD_SUSFS_ADD_SUS_PATH_LOOP)       { susfs_add_sus_path_loop(arg); return 0; }
+#endif
+#ifdef CONFIG_KSU_SUSFS_SUS_MOUNT
+        if (cmd == CMD_SUSFS_HIDE_SUS_MNTS_FOR_NON_SU_PROCS) { susfs_set_hide_sus_mnts_for_non_su_procs(arg); return 0; }
+#endif
+#ifdef CONFIG_KSU_SUSFS_SUS_KSTAT
+        if (cmd == CMD_SUSFS_ADD_SUS_KSTAT)           { susfs_add_sus_kstat(arg); return 0; }
+        if (cmd == CMD_SUSFS_UPDATE_SUS_KSTAT)        { susfs_update_sus_kstat(arg); return 0; }
+        if (cmd == CMD_SUSFS_ADD_SUS_KSTAT_STATICALLY){ susfs_add_sus_kstat(arg); return 0; }
+#endif
+#ifdef CONFIG_KSU_SUSFS_SPOOF_UNAME
+        if (cmd == CMD_SUSFS_SET_UNAME)               { susfs_set_uname(arg); return 0; }
+#endif
+#ifdef CONFIG_KSU_SUSFS_ENABLE_LOG
+        if (cmd == CMD_SUSFS_ENABLE_LOG)              { susfs_enable_log(arg); return 0; }
+#endif
+#ifdef CONFIG_KSU_SUSFS_SPOOF_CMDLINE_OR_BOOTCONFIG
+        if (cmd == CMD_SUSFS_SET_CMDLINE_OR_BOOTCONFIG) { susfs_set_cmdline_or_bootconfig(arg); return 0; }
+#endif
+#ifdef CONFIG_KSU_SUSFS_OPEN_REDIRECT
+        if (cmd == CMD_SUSFS_ADD_OPEN_REDIRECT)       { susfs_add_open_redirect(arg); return 0; }
+#endif
+#ifdef CONFIG_KSU_SUSFS_SUS_MAP
+        if (cmd == CMD_SUSFS_ADD_SUS_MAP)             { susfs_add_sus_map(arg); return 0; }
+#endif
+        if (cmd == CMD_SUSFS_ENABLE_AVC_LOG_SPOOFING) { susfs_set_avc_log_spoofing(arg); return 0; }
+        if (cmd == CMD_SUSFS_SHOW_ENABLED_FEATURES)   { susfs_get_enabled_features(arg); return 0; }
+        if (cmd == CMD_SUSFS_SHOW_VARIANT)            { susfs_show_variant(arg); return 0; }
+        if (cmd == CMD_SUSFS_SHOW_VERSION)            { susfs_show_version(arg); return 0; }
+        return -EINVAL;
+    }
+#endif // CONFIG_KSU_SUSFS
+
+
     if (magic1 != KSU_INSTALL_MAGIC1)
     	return 0;
 
